#!/bin/sh
# gsc wrapper that injects extra modules into gsc -link calls.
# Injects:
#   1. gambitgsc .c files — embeds the Gambit compiler (compile-file)
#   2. gerbil-runtime .scm files — embeds missing Gerbil runtime modules
#      so the static binary doesn't need -:~~=/path/to/gerbil
#
# Usage: GERBIL_GSC=/path/to/this/script gerbil build
#
# CRITICAL: files must be injected BEFORE the last argument of gsc -link,
# because gsc derives the output linkfile name from the last input file
# (e.g., gsh__exe.scm -> gsh__exe_.c).
#
# CRITICAL: gambitgsc modules must be listed in dependency order (from
# LINK_ORDER), NOT alphabetical. Wrong order causes segfaults.
#
# gsc -link with incremental linking generates sub-linkfiles in the
# injected directories. We delete them after the link step to prevent
# duplicate symbol errors at final link time.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
GAMBITGSC_DIR="$PROJECT_DIR/_vendor/gambitgsc"
RUNTIME_DIR="$PROJECT_DIR/_vendor/gerbil-runtime"

# Find the real gsc
if [ -n "$GERBIL_HOME" ]; then
  REAL_GSC="$GERBIL_HOME/bin/gsc"
elif [ -x /opt/gerbil/bin/gsc ]; then
  REAL_GSC=/opt/gerbil/bin/gsc
else
  REAL_GSC="$(which gsc 2>/dev/null)"
fi

if [ ! -x "$REAL_GSC" ]; then
  echo "gsc-with-gambitgsc: cannot find real gsc" >&2
  exit 1
fi

# Check if this is a -link call
is_link=false
for arg in "$@"; do
  if [ "$arg" = "-link" ]; then
    is_link=true
    break
  fi
done

if $is_link; then
  inject_files=""

  # 1. Gambitgsc .c files (compiler modules)
  if [ -d "$GAMBITGSC_DIR" ] && [ -f "$GAMBITGSC_DIR/LINK_ORDER" ]; then
    while IFS= read -r f; do
      case "$f" in ''|'#'*) continue ;; esac
      inject_files="$inject_files $GAMBITGSC_DIR/$f"
    done < "$GAMBITGSC_DIR/LINK_ORDER"
  fi

  # 2. Gerbil-runtime .c files (missing runtime modules, static builds only)
  if [ -n "${GSH_STATIC:-}" ] && [ -d "$RUNTIME_DIR" ] && [ -f "$RUNTIME_DIR/LINK_ORDER" ]; then
    while IFS= read -r f; do
      case "$f" in ''|'#'*) continue ;; esac
      inject_files="$inject_files $RUNTIME_DIR/$f"
    done < "$RUNTIME_DIR/LINK_ORDER"
  fi

  if [ -n "$inject_files" ]; then
    # Separate head args (all but last) and last arg.
    # gsc -link args are flags and file paths (no spaces), so word splitting is safe.
    last_arg=
    prev_args=
    for arg in "$@"; do
      if [ -n "$last_arg" ]; then
        prev_args="$prev_args $last_arg"
      fi
      last_arg="$arg"
    done

    # Snapshot files before gsc -link so we only clean up NEW files after.
    # gsc -link generates sub-linkfiles (init wrappers) in the injected
    # directories. Blind *_.c/*_.o patterns would also delete our real
    # input files like gerbil__polydactyl~_extern_.c whose name ends in _.
    _snap_dir=$(mktemp -d /tmp/gsc-snap.XXXXXX)
    ls "$GAMBITGSC_DIR" 2>/dev/null | sort > "$_snap_dir/before_gsc"
    ls "$RUNTIME_DIR" 2>/dev/null | sort > "$_snap_dir/before_rt"

    # shellcheck disable=SC2086
    "$REAL_GSC" $prev_args $inject_files "$last_arg"
    rc=$?

    # Clean up sub-linkfiles generated by gsc -link (init wrappers).
    # Only delete files that are NEW (not in the pre-link snapshot).
    ls "$GAMBITGSC_DIR" 2>/dev/null | sort > "$_snap_dir/after_gsc"
    ls "$RUNTIME_DIR" 2>/dev/null | sort > "$_snap_dir/after_rt"

    for f in $(comm -13 "$_snap_dir/before_gsc" "$_snap_dir/after_gsc"); do
      rm -f "$GAMBITGSC_DIR/$f"
    done
    for f in $(comm -13 "$_snap_dir/before_rt" "$_snap_dir/after_rt"); do
      rm -f "$RUNTIME_DIR/$f"
    done
    rm -rf "$_snap_dir"

    exit $rc
  else
    exec "$REAL_GSC" "$@"
  fi
else
  exec "$REAL_GSC" "$@"
fi
