#!/bin/sh
# Generate _vendor/gerbil-runtime/ contents from the user's installed Gerbil.
#
# This script:
# 1. Finds .scm files in $GERBIL_HOME/lib/static/ that lack .o (195 modules)
# 2. Compiles each with gsc -obj to produce .o files
# 3. Generates LINK_ORDER listing the .scm filenames for gsc -link injection
# 4. Collects all .ssi files from $GERBIL_HOME/lib/ and generates embedded_ssi.c
#    with a lookup table so the static binary can resolve .ssi from memory
# 5. Creates a gzip-compressed archive of all .scm files from $GERBIL_HOME/lib/
#    (the runtime modules that load-module needs) and embeds it in embedded_scm.c
# 6. Compiles embedded_ssi.c and embedded_scm.c to .o files
#
# The generated files enable a fully self-contained static binary that
# doesn't need -:~~=/path/to/gerbil for ,eval and ,use.

set -eu

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
RUNTIME_DIR="$PROJECT_DIR/_vendor/gerbil-runtime"
VERSION_STAMP="$RUNTIME_DIR/.gerbil-version"

# --- Detect Gerbil ---

if [ -n "${GERBIL_HOME:-}" ]; then
  GSC="$GERBIL_HOME/bin/gsc"
  GERBIL_LIB="$GERBIL_HOME/lib"
else
  GSC="$(which gsc 2>/dev/null || true)"
  GERBIL_LIB="$(gxi -e '(display (path-expand "~~lib"))' 2>/dev/null || true)"
fi

if [ -z "$GSC" ] || [ ! -x "$GSC" ]; then
  echo "generate-gerbil-runtime: cannot find gsc" >&2
  exit 1
fi
if [ -z "$GERBIL_LIB" ] || [ ! -d "$GERBIL_LIB" ]; then
  echo "generate-gerbil-runtime: cannot find Gerbil lib directory" >&2
  exit 1
fi

STATIC_DIR="$GERBIL_LIB/static"
if [ ! -d "$STATIC_DIR" ]; then
  echo "generate-gerbil-runtime: static directory not found at $STATIC_DIR" >&2
  exit 1
fi

GSC_VERSION=$("$GSC" -v 2>&1 | head -1)
GERBIL_VERSION=$(gxi -e '(display (system-version))' 2>/dev/null || echo "unknown")

echo "Gerbil lib: $GERBIL_LIB"
echo "GSC version: $GSC_VERSION"

# --- Check if already generated ---

STAMP_VALUE="$GSC_VERSION $GERBIL_LIB"
if [ -f "$VERSION_STAMP" ] && [ "$(cat "$VERSION_STAMP")" = "$STAMP_VALUE" ]; then
  if ls "$RUNTIME_DIR"/*.o >/dev/null 2>&1 && [ -f "$RUNTIME_DIR/LINK_ORDER" ]; then
    echo "gerbil-runtime already up-to-date"
    exit 0
  fi
fi

# --- Prepare output directory ---

mkdir -p "$RUNTIME_DIR"
rm -f "$RUNTIME_DIR"/*.o "$RUNTIME_DIR"/*.scm "$RUNTIME_DIR"/LINK_ORDER "$VERSION_STAMP"
rm -f "$RUNTIME_DIR"/embedded_ssi.c "$RUNTIME_DIR"/embedded_ssi.o
rm -f "$RUNTIME_DIR"/embedded_scm.c "$RUNTIME_DIR"/embedded_scm.o

# --- Part 1: Find and compile missing .scm files ---

echo "Scanning for .scm files without .o in $STATIC_DIR..."

# Collect list of .scm files that need compilation
SCM_LIST=""
SCM_COUNT=0
for f in "$STATIC_DIR"/*.scm; do
  [ -f "$f" ] || continue
  base="${f%.scm}"
  if [ ! -f "$base.o" ]; then
    name=$(basename "$f")
    SCM_LIST="$SCM_LIST $name"
    SCM_COUNT=$((SCM_COUNT + 1))
  fi
done

echo "Found $SCM_COUNT .scm files to compile"

# Compile each .scm to .c (for gsc -link) and .o (for final linking)
# gsc -c generates a .c file from .scm (used by gsc -link for init chain)
# gsc -obj generates a .o file from .scm (actual compiled code for linking)
echo "Compiling .scm files to .c + .o..."
FAIL=0
DONE=0
for name in $SCM_LIST; do
  src="$STATIC_DIR/$name"
  cfile="$RUNTIME_DIR/${name%.scm}.c"
  ofile="$RUNTIME_DIR/${name%.scm}.o"
  DONE=$((DONE + 1))
  if [ $((DONE % 20)) -eq 0 ] || [ "$DONE" -eq "$SCM_COUNT" ]; then
    printf "  [%d/%d] %s\n" "$DONE" "$SCM_COUNT" "$name"
  fi
  if ! "$GSC" -c -o "$cfile" "$src" >/dev/null 2>&1; then
    echo "  ERROR: gsc -c failed for $name" >&2
    FAIL=1
    continue
  fi
  if ! "$GSC" -obj -o "$ofile" "$src" >/dev/null 2>&1; then
    echo "  ERROR: gsc -obj failed for $name" >&2
    FAIL=1
  fi
done

if [ "$FAIL" -ne 0 ]; then
  echo "generate-gerbil-runtime: some .scm files failed to compile" >&2
  exit 1
fi

# --- Generate LINK_ORDER (lists .c files for gsc -link injection) ---

echo "Generating LINK_ORDER..."
for name in $SCM_LIST; do
  echo "${name%.scm}.c"
done > "$RUNTIME_DIR/LINK_ORDER"

# --- Part 2: Generate embedded_ssi.c ---

echo "Generating embedded_ssi.c from .ssi files..."

SSI_COUNT=0
SSI_C="$RUNTIME_DIR/embedded_ssi.c"

# Start the C file
cat > "$SSI_C" <<'HEADER'
/* Auto-generated by scripts/generate-gerbil-runtime — do not edit */
#include <string.h>

struct gsh_ssi_entry {
    const char *path;
    const char *data;
    unsigned int size;
};

HEADER

# Generate per-file string constants
# We use a Python helper for proper C string escaping
python3 - "$GERBIL_LIB" "$SSI_C" <<'PYSCRIPT'
import sys, os, glob

lib_dir = sys.argv[1]
out_file = sys.argv[2]

# Find all .ssi files
ssi_files = []
for root, dirs, files in os.walk(lib_dir):
    for f in files:
        if f.endswith('.ssi'):
            full = os.path.join(root, f)
            rel = os.path.relpath(full, lib_dir)
            ssi_files.append((rel, full))

ssi_files.sort(key=lambda x: x[0])

with open(out_file, 'a') as out:
    # Write each file as a C string constant
    for i, (rel, full) in enumerate(ssi_files):
        with open(full, 'r') as sf:
            data = sf.read()
        # C string escape
        escaped = data.replace('\\', '\\\\').replace('"', '\\"').replace('\n', '\\n').replace('\t', '\\t').replace('\r', '\\r')
        var_name = f"ssi_data_{i}"
        out.write(f'static const char {var_name}[] = "{escaped}";\n\n')

    # Write the table
    out.write('static const struct gsh_ssi_entry gsh_ssi_table[] = {\n')
    for i, (rel, full) in enumerate(ssi_files):
        size = os.path.getsize(full)
        out.write(f'    {{"{rel}", ssi_data_{i}, {size}}},\n')
    out.write('    {NULL, NULL, 0}\n')
    out.write('};\n\n')

    # Write table size
    out.write(f'static const int gsh_ssi_table_size = {len(ssi_files)};\n\n')

    # Write binary search lookup (table is sorted by path)
    out.write('''/* Binary search for an embedded .ssi file by path.
   Returns pointer to data and sets *size, or NULL if not found. */
const char* gsh_find_embedded_ssi(const char *path, unsigned int *size) {
    int lo = 0, hi = gsh_ssi_table_size - 1;
    while (lo <= hi) {
        int mid = (lo + hi) / 2;
        int cmp = strcmp(path, gsh_ssi_table[mid].path);
        if (cmp == 0) {
            if (size) *size = gsh_ssi_table[mid].size;
            return gsh_ssi_table[mid].data;
        } else if (cmp < 0) {
            hi = mid - 1;
        } else {
            lo = mid + 1;
        }
    }
    return NULL;
}
''')

    # Write extraction function
    out.write('''
#include <stdio.h>
#include <sys/stat.h>
#include <errno.h>
#include <libgen.h>

/* Ensure all parent directories exist for a file path */
static int mkdirs(const char *filepath) {
    char tmp[4096];
    snprintf(tmp, sizeof(tmp), "%s", filepath);
    /* Find last / to get directory part */
    char *last_slash = strrchr(tmp, '/');
    if (!last_slash) return 0;
    *last_slash = '\\0';
    /* Create each directory component */
    for (char *p = tmp + 1; *p; p++) {
        if (*p == '/') {
            *p = '\\0';
            mkdir(tmp, 0755);
            *p = '/';
        }
    }
    mkdir(tmp, 0755);
    return 0;
}

/* Extract all embedded .ssi files to a directory.
   Returns number of files extracted, or -1 on error. */
int gsh_extract_embedded_ssi(const char *base_dir) {
    int count = 0;
    char path[4096];
    for (int i = 0; i < gsh_ssi_table_size; i++) {
        snprintf(path, sizeof(path), "%s/%s", base_dir, gsh_ssi_table[i].path);
        mkdirs(path);
        FILE *f = fopen(path, "w");
        if (!f) return -1;
        fwrite(gsh_ssi_table[i].data, 1, gsh_ssi_table[i].size, f);
        fclose(f);
        count++;
    }
    return count;
}

/* Check if embedded .ssi data is available (table is non-empty) */
int gsh_has_embedded_ssi(void) {
    return gsh_ssi_table_size > 0;
}
''')

    print(f"  {len(ssi_files)} .ssi files embedded ({sum(os.path.getsize(f) for _, f in ssi_files)} bytes)")
PYSCRIPT

# Compile embedded_ssi.c to .o
echo "Compiling embedded_ssi.c..."
cc -O2 -c "$SSI_C" -o "$RUNTIME_DIR/embedded_ssi.o"

# --- Part 3: Generate embedded_scm.c (compressed .scm archive) ---
# The lib/ .scm files contain the runtime module code that load-module
# needs to evaluate. They are different from the static/ .scm files
# (which are empty placeholders for module registration). Without these,
# the expander cannot load numbered sub-modules referenced by .ssi files.
# We compress them as gzip to keep the binary small (~4MB vs ~49MB raw).

echo "Creating compressed .scm archive..."

SCM_ARCHIVE="$RUNTIME_DIR/scm_archive.tar.gz"
SCM_C="$RUNTIME_DIR/embedded_scm.c"

# Create tar.gz of all .scm files in lib/ (excluding static/)
(cd "$GERBIL_LIB" && find . -name "*.scm" -not -path "*/static/*" -type f | tar czf "$SCM_ARCHIVE" -T -)
SCM_ARCHIVE_SIZE=$(wc -c < "$SCM_ARCHIVE")
echo "  Archive: $SCM_ARCHIVE_SIZE bytes (compressed)"

# Convert the archive to a C byte array
python3 - "$SCM_ARCHIVE" "$SCM_C" <<'PYSCRIPT'
import sys

archive_path = sys.argv[1]
out_path = sys.argv[2]

with open(archive_path, 'rb') as f:
    data = f.read()

with open(out_path, 'w') as out:
    out.write('/* Auto-generated by scripts/generate-gerbil-runtime -- do not edit */\n')
    out.write('#include <stdio.h>\n')
    out.write('#include <stdlib.h>\n')
    out.write('#include <string.h>\n\n')

    # Write the compressed data as a C byte array
    out.write(f'static const unsigned char gsh_scm_archive_data[] = {{\n')
    for i in range(0, len(data), 16):
        chunk = data[i:i+16]
        hex_bytes = ', '.join(f'0x{b:02x}' for b in chunk)
        out.write(f'    {hex_bytes},\n')
    out.write('};\n\n')
    out.write(f'static const unsigned int gsh_scm_archive_size = {len(data)};\n\n')

    # Write extraction function using popen to tar
    out.write('''/* Extract embedded .scm archive to a directory.
   Uses system tar to decompress. Returns 0 on success. */
int gsh_extract_embedded_scm(const char *base_dir) {
    char cmd[4096];
    snprintf(cmd, sizeof(cmd), "tar xzf - -C '%s'", base_dir);
    FILE *p = popen(cmd, "w");
    if (!p) return -1;
    size_t written = fwrite(gsh_scm_archive_data, 1, gsh_scm_archive_size, p);
    int rc = pclose(p);
    if (written != gsh_scm_archive_size) return -2;
    return rc;
}

/* Check if embedded .scm archive is available */
int gsh_has_embedded_scm(void) {
    return gsh_scm_archive_size > 0;
}
''')

print(f"  Generated embedded_scm.c ({len(data)} bytes compressed)")
PYSCRIPT

rm -f "$SCM_ARCHIVE"

# Compile embedded_scm.c to .o
echo "Compiling embedded_scm.c..."
cc -O2 -c "$SCM_C" -o "$RUNTIME_DIR/embedded_scm.o"

# --- Part 4: Embed gambit.h for compile-file support ---
# The static binary's embedded compiler (compile-file) needs gambit.h to
# compile .c → .o1. We embed both header files so compile-file works
# without a Gambit installation on the target system.

INCLUDE_DIR="$GERBIL_LIB/../include"
GAMBIT_H_C="$RUNTIME_DIR/embedded_gambit_h.c"

if [ -f "$INCLUDE_DIR/gambit.h" ]; then
  echo "Embedding gambit.h for compile-file support..."

  python3 - "$INCLUDE_DIR" "$GAMBIT_H_C" <<'PYSCRIPT'
import sys, os

include_dir = sys.argv[1]
out_path = sys.argv[2]

files = []
for name in ['gambit.h', 'gambit-not409007.h']:
    path = os.path.join(include_dir, name)
    if os.path.exists(path):
        with open(path, 'rb') as f:
            files.append((name, f.read()))

with open(out_path, 'w') as out:
    out.write('/* Auto-generated by scripts/generate-gerbil-runtime -- do not edit */\n')
    out.write('#include <stdio.h>\n')
    out.write('#include <string.h>\n')
    out.write('#include <sys/stat.h>\n\n')

    # Write each header as a byte array
    for i, (name, data) in enumerate(files):
        out.write(f'static const unsigned char gsh_header_{i}[] = {{\n')
        for j in range(0, len(data), 16):
            chunk = data[j:j+16]
            hex_bytes = ', '.join(f'0x{b:02x}' for b in chunk)
            out.write(f'    {hex_bytes},\n')
        out.write('};\n\n')

    # Write table
    out.write('struct gsh_header_entry { const char *name; const unsigned char *data; unsigned int size; };\n')
    out.write('static const struct gsh_header_entry gsh_header_table[] = {\n')
    for i, (name, data) in enumerate(files):
        out.write(f'    {{"{name}", gsh_header_{i}, {len(data)}}},\n')
    out.write('    {NULL, NULL, 0}\n')
    out.write('};\n\n')

    out.write(f'static const int gsh_header_table_size = {len(files)};\n\n')

    # Write extraction function
    out.write('''/* Extract embedded header files to include_dir/.
   Creates include_dir if needed. Returns 0 on success. */
int gsh_extract_embedded_headers(const char *include_dir) {
    mkdir(include_dir, 0755);
    char path[4096];
    for (int i = 0; i < gsh_header_table_size; i++) {
        snprintf(path, sizeof(path), "%s/%s", include_dir, gsh_header_table[i].name);
        FILE *f = fopen(path, "w");
        if (!f) return -1;
        fwrite(gsh_header_table[i].data, 1, gsh_header_table[i].size, f);
        fclose(f);
    }
    return 0;
}

int gsh_has_embedded_headers(void) {
    return gsh_header_table_size > 0;
}
''')

    total = sum(len(d) for _, d in files)
    print(f"  {len(files)} header files embedded ({total} bytes)")
PYSCRIPT

  echo "Compiling embedded_gambit_h.c..."
  cc -O2 -c "$GAMBIT_H_C" -o "$RUNTIME_DIR/embedded_gambit_h.o"
else
  echo "Warning: gambit.h not found at $INCLUDE_DIR, skipping header embedding"
fi

# --- Write version stamp ---

echo "$STAMP_VALUE" > "$VERSION_STAMP"

echo "Done: $SCM_COUNT .scm → .o, plus embedded_ssi.o + embedded_scm.o + embedded_gambit_h.o"
